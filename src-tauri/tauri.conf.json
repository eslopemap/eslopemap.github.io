{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slope Mapper",
  "version": "0.1.0",
  "identifier": "com.eslopemap.slope",
  "build": {
    "frontendDist": "../app",
    "devUrl": "http://localhost:8089/app/",
    "beforeDevCommand": "python3 -m http.server 8089"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Slope Mapper",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/icon.png"]
  }
}
